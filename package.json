{
  "name": "afterimage-captcha",
  "version": "0.1.0",
  "description": "A dependency-free, display-synced Canvas CAPTCHA using visual persistence and complementary noise frames.",
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "README.zh-CN.md"
  ],
  "keywords": [
    "captcha",
    "canvas",
    "requestanimationframe",
    "afterimage",
    "ocr",
    "visual-persistence"
  ],
  "author": "PPPPigggg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PPPPigggg/afterimage-captcha.git"
  },
  "homepage": "https://ppppigggg.github.io/afterimage-captcha/",
  "bugs": {
    "url": "https://github.com/PPPPigggg/afterimage-captcha/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch --no-clean",
    "dev:all": "pnpm build && pnpm --parallel --recursive --include-workspace-root dev",
    "format": "biome format --write",
    "lint": "biome check .",
    "playground": "pnpm --dir playground dev",
    "playground:build": "pnpm --dir playground build",
    "prepublishOnly": "pnpm run lint && pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@rslib/core": "^0.23.2",
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3"
  }
}

{
  "name": "afterimage-captcha",
  "version": "0.1.0",
  "description": "Generate display-synced Canvas captchas from complementary television snow frames.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "captcha",
    "canvas",
    "requestanimationframe",
    "afterimage",
    "ocr",
    "visual-persistence"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch --no-clean",
    "dev:all": "pnpm build && pnpm --parallel --recursive --include-workspace-root dev",
    "format": "biome format --write",
    "lint": "biome check .",
    "playground": "pnpm --dir playground dev",
    "playground:build": "pnpm --dir playground build",
    "test": "rstest run",
    "test:watch": "rstest --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@rslib/core": "^0.23.2",
    "@rstest/adapter-rslib": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3"
  }
}
